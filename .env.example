NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
NEXT_PUBLIC_SIGNAL_LIVE=0
NEXT_PUBLIC_SIGNAL_FUTURE=1

# Client-side ICE (mock / dev)
NEXT_PUBLIC_SIGNAL_STUN_URLS=stun:stun.l.google.com:19302
NEXT_PUBLIC_SIGNAL_TURN_URLS=
NEXT_PUBLIC_SIGNAL_TURN_USERNAME=
NEXT_PUBLIC_SIGNAL_TURN_CREDENTIAL=
NEXT_PUBLIC_SIGNAL_ICE_SERVERS_JSON=

# Server-side ICE (live / production — secrets stay off the client)
SIGNAL_STUN_URLS=stun:stun.l.google.com:19302
SIGNAL_TURN_URLS=
SIGNAL_TURN_USERNAME=
SIGNAL_TURN_CREDENTIAL=
SIGNAL_TURN_SECRET=
SIGNAL_ICE_SERVERS_JSON=

SIGNAL_ENFORCE_TURN_RELAY=0
SIGNAL_DEBUG_EXPORT_TOKEN=
CRON_SECRET=

# Vercel cron hits /api/cron/cleanup daily when CRON_SECRET is set.
# Production voice behind NAT requires TURN — e.g. Metered.ca, Cloudflare Calls, or self-hosted coturn:
# SIGNAL_TURN_URLS=turn:global.relay.metered.ca:80,turn:global.relay.metered.ca:443,turns:global.relay.metered.ca:443?transport=tcp
# SIGNAL_TURN_USERNAME=your-metered-username
# SIGNAL_TURN_CREDENTIAL=your-metered-credential
# Or use SIGNAL_TURN_SECRET with time-limited HMAC credentials (coturn static-auth-secret).
